# /etc/systemd/system/rnsa-cycle.service
[Unit]
Description=RNSA Iceland (aviation) ingest cycle (weekly; discover->fetch->build)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=scraper
WorkingDirectory=/opt/rnsa
ExecStart=/bin/bash -lc "deploy/run-cycle.sh"
StandardOutput=append:/opt/rnsa/rnsa-cycle.log
StandardError=append:/opt/rnsa/rnsa-cycle.log
TimeoutStartSec=7200
