# /etc/systemd/system/aaibmy-cycle.service
[Unit]
Description=AAIB Malaysia ingest cycle (weekly; discover->fetch->build)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=scraper
WorkingDirectory=/opt/aaibmy
ExecStart=/bin/bash -lc "deploy/run-cycle.sh"
StandardOutput=append:/opt/aaibmy/aaibmy-cycle.log
StandardError=append:/opt/aaibmy/aaibmy-cycle.log
TimeoutStartSec=7200
