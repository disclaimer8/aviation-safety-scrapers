# /etc/systemd/system/gcaa-cycle.service
[Unit]
Description=GCAA (UAE) ingest cycle (weekly; discover->fetch->build)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=scraper
WorkingDirectory=/opt/gcaa
ExecStart=/bin/bash -lc "deploy/run-cycle.sh"
StandardOutput=append:/opt/gcaa/gcaa-cycle.log
StandardError=append:/opt/gcaa/gcaa-cycle.log
TimeoutStartSec=7200
