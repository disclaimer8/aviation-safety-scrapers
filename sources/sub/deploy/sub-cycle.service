# /etc/systemd/system/sub-cycle.service
[Unit]
Description=SUB Austria ingest cycle (weekly; discover->fetch->build)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=scraper
WorkingDirectory=/opt/sub
ExecStart=/bin/bash -lc "deploy/run-cycle.sh"
StandardOutput=append:/opt/sub/sub-cycle.log
StandardError=append:/opt/sub/sub-cycle.log
TimeoutStartSec=7200
