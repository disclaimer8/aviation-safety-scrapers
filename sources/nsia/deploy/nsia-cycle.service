# /etc/systemd/system/nsia-cycle.service
[Unit]
Description=NSIA (Norway) ingest cycle (weekly; discover->fetch->build)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=scraper
WorkingDirectory=/opt/nsia
ExecStart=/bin/bash -lc "deploy/run-cycle.sh"
StandardOutput=append:/opt/nsia/nsia-cycle.log
StandardError=append:/opt/nsia/nsia-cycle.log
TimeoutStartSec=7200
