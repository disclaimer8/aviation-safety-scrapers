# /etc/systemd/system/ovv-cycle.service
[Unit]
Description=OVV (Netherlands) ingest cycle (weekly; discover->fetch->build)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=scraper
WorkingDirectory=/opt/ovv
ExecStart=/bin/bash -lc "deploy/run-cycle.sh"
StandardOutput=append:/opt/ovv/ovv-cycle.log
StandardError=append:/opt/ovv/ovv-cycle.log
TimeoutStartSec=14400
