# /etc/systemd/system/pkbwl-cycle.service
[Unit]
Description=PKBWL Poland ingest cycle (weekly; discover->fetch->build)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=scraper
WorkingDirectory=/opt/pkbwl
ExecStart=/bin/bash -lc "deploy/run-cycle.sh"
StandardOutput=append:/opt/pkbwl/pkbwl-cycle.log
StandardError=append:/opt/pkbwl/pkbwl-cycle.log
TimeoutStartSec=14400
