# /etc/systemd/system/tsib-cycle.service
[Unit]
Description=TSIB (Singapore) ingest cycle (weekly; discover->fetch->build)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=scraper
WorkingDirectory=/opt/tsib
ExecStart=/bin/bash -lc "deploy/run-cycle.sh"
StandardOutput=append:/opt/tsib/tsib-cycle.log
StandardError=append:/opt/tsib/tsib-cycle.log
TimeoutStartSec=7200
