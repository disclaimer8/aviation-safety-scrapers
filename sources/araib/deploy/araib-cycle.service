# /etc/systemd/system/araib-cycle.service
[Unit]
Description=ARAIB South Korea ingest cycle (weekly; discover->fetch->build)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=scraper
WorkingDirectory=/opt/araib
ExecStart=/bin/bash -lc "deploy/run-cycle.sh"
StandardOutput=append:/opt/araib/araib-cycle.log
StandardError=append:/opt/araib/araib-cycle.log
TimeoutStartSec=7200
