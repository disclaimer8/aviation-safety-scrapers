# /etc/systemd/system/uzpln-cycle.service
[Unit]
Description=UZPLN (Czech Republic) ingest cycle (weekly; discover->fetch->build)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=scraper
WorkingDirectory=/opt/uzpln
ExecStart=/bin/bash -lc "deploy/run-cycle.sh"
StandardOutput=append:/opt/uzpln/uzpln-cycle.log
StandardError=append:/opt/uzpln/uzpln-cycle.log
TimeoutStartSec=7200
