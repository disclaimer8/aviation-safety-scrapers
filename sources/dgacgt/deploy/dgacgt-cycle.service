# /etc/systemd/system/dgacgt-cycle.service
[Unit]
Description=DGAC Guatemala (UIA) ingest cycle (weekly; discover->fetch->parse->build)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=scraper
WorkingDirectory=/opt/dgacgt
ExecStart=/bin/bash -lc "deploy/run-cycle.sh"
StandardOutput=append:/opt/dgacgt/dgacgt-cycle.log
StandardError=append:/opt/dgacgt/dgacgt-cycle.log
TimeoutStartSec=10800
