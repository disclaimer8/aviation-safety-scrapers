# /etc/systemd/system/ueim-cycle.service
[Unit]
Description=UEIM Turkey ingest cycle (weekly; discover->fetch->build)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=scraper
WorkingDirectory=/opt/ueim
ExecStart=/bin/bash -lc "deploy/run-cycle.sh"
StandardOutput=append:/opt/ueim/ueim-cycle.log
StandardError=append:/opt/ueim/ueim-cycle.log
TimeoutStartSec=7200
