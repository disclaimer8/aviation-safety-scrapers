# /etc/systemd/system/taic-cycle.service
[Unit]
Description=TAIC (New Zealand) ingest cycle (weekly; discover->fetch->build)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=scraper
WorkingDirectory=/opt/taic
ExecStart=/bin/bash -lc "deploy/run-cycle.sh"
StandardOutput=append:/opt/taic/taic-cycle.log
StandardError=append:/opt/taic/taic-cycle.log
TimeoutStartSec=7200
